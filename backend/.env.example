# Copy to .env and fill in values. Do not commit real secrets.

DATABASE_PATH=souschef.db
CORS_ORIGINS=http://localhost:3000

# Dev server port for scripts/start-uvicorn.ps1 when you do not pass -Port (default in script is 8001).
# Use 8001 if something else already owns 8000 on Windows.
# SOUSCHEF_UVICORN_PORT=8001

# K2 Think V2 (MBZUAI) for POST /recipes/parse
K2_THINK_API_KEY=
K2_THINK_BASE_URL=https://api.k2think.ai/v1
K2_THINK_MODEL=MBZUAI-IFM/K2-Think-v2
# Google Gemini (POST /recipes/suggest-personalized — JSON meal ideas; use GOOGLE_API_KEY or GEMINI_API_KEY)
# GOOGLE_API_KEY=
# Optional model id (default: gemini-2.5-flash). Try gemini-2.0-flash or gemini-1.5-flash if needed.
# GEMINI_SUGGEST_MODEL=gemini-2.5-flash

# Knot (web Express create-session + FastAPI /profile/sync use the same keys)
KNOT_CLIENT_ID=
KNOT_CLIENT_SECRET=
# Server-side sync (POST https://api.knotapi.com/transactions/sync)
KNOT_API_BASE=https://api.knotapi.com
# DoorDash in Knot’s catalog is often 19 for verification; override if needed
KNOT_DEFAULT_MERCHANT_ID=19

# Optional: stock photos for POST /recipes/suggest-personalized (server-side only; never commit real key)
# PEXELS_API_KEY=
